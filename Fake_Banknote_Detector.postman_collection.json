							"pm.test(\"Le statut est 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Ce billet DOIT être valide\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.is_fake).to.be.false;",
							"});"
